              "value": "application/json"
            }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\"model\":\"gpt-4o-mini\",\"messages\":[{\"role\":\"system\",\"content\":\"Return exactly the requested sections.\"},{\"role\":\"user\",\"content\":\"Keyword: {{$json.keyword}}\\nProduct: {{$json.product}}\\nScenario: {{$json.scenario}}\\n\\nReturn sections:\\n=== ARTICLE ===\\n=== IMAGE_PROMPT_25 ===\\n=== IMAGE_PROMPT_50 ===\\n=== IMAGE_PROMPT_75 ===\\n=== QUALITY_NOTES ===\"}]}"
      },
      "id": "call-openai",
      "name": "Call OpenAI",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        980,
        360
      ],
      "notes": "Swap for Anthropic if needed."
    },
    {
      "parameters": {
        "jsCode": "const text = $json.choices?.[0]?.message?.content || '';\nconst grab = (name, next) => {\n  const pattern = next ? new RegExp(`===\\\\s*${name}\\\\s*===([\\\\s\\\\S]*?)===\\\\s*${next}\\\\s*===`) : new RegExp(`===\\\\s*${name}\\\\s*===([\\\\s\\\\S]*)$`);\n  const match = text.match(pattern);\n  return match ? match[1].trim() : '';\n};\nreturn [{ json: { timestamp: new Date().toISOString(), input_row: $item(0).$node['Pick First SEO Pending'].json.row_number || '', keyword: $item(0).$node['Pick First SEO Pending'].json.keyword || '', product: $item(0).$node['Pick First SEO Pending'].json.product || '', scenario: $item(0).$node['Pick First SEO Pending'].json.scenario || '', article: grab('ARTICLE', 'IMAGE_PROMPT_25'), image_prompt_25: grab('IMAGE_PROMPT_25', 'IMAGE_PROMPT_50'), image_prompt_50: grab('IMAGE_PROMPT_50', 'IMAGE_PROMPT_75'), image_prompt_75: grab('IMAGE_PROMPT_75', 'QUALITY_NOTES'), quality_notes: grab('QUALITY_NOTES'), mode: 'live' } }];"
      },
