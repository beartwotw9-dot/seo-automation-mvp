      "parameters": {
        "jsCode": "const organic = ($json.organic_results || []).slice(0, 10);\nreturn organic.map((row, index) => ({ json: { timestamp: new Date().toISOString(), input_row: $item(0).$node['Pick First SERP Pending'].json.row_number || '', keyword: $item(0).$node['Pick First SERP Pending'].json.keyword || '', position: index + 1, title: row.title || '', link: row.link || row.url || '', snippet: row.snippet || row.description || '', top_entities: 'TODO: parse entities in Code node', token_count: '', mode: 'live' } }));"
      },
